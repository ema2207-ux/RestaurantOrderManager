<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.restaurant.gui.LoginController" style="-fx-background-color: #2c3e50;">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="RESTO MANAGER" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Label text="Introduceți codul PIN" style="-fx-text-fill: #bdc3c7;"/>

    <PasswordField fx:id="pinField" promptText="PIN" style="-fx-font-size: 18px; -fx-alignment: center;"/>

    <Button text="AUTENTIFICARE" onAction="#handleLogin" maxWidth="Infinity"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10;"/>

    <Button text="CREEAZĂ CONT STAFF" onAction="#handleShowRegister" maxWidth="Infinity"
            style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-border-color: #3498db; -fx-border-radius: 5; -fx-padding: 8;"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c;"/>
</VBox>
