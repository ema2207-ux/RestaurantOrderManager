<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.restaurant.gui.RestaurantController"
            stylesheets="@style.css"
            prefHeight="850.0" prefWidth="1280.0">

    <top>
        <VBox>
            <MenuBar>
                <menus>
                    <Menu text="Sistem">
                        <items>
                            <MenuItem text="Refresh Date" onAction="#handleRefreshData"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="Ieșire" onAction="#handleExit"/>
                        </items>
                    </Menu>
                    <Menu text="Ajutor">
                        <items>
                            <MenuItem text="Despre" onAction="#handleAbout"/>
                        </items>
                    </Menu>
                </menus>
            </MenuBar>
            <HBox spacing="20" alignment="CENTER_LEFT" styleClass="header-bar">
                <Label text="RESTO" style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: #007bff;"/>
                <Label text="PRO" style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: #34495e; -fx-translate-x: -18;"/>
                <Separator orientation="VERTICAL" style="-fx-padding: 0 10;"/>
                <Label text="Dashboard de Gestiune" style="-fx-text-fill: #6c757d; -fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Deconectare ↩" onAction="#handleLogout" styleClass="button-danger"/>
            </HBox>
        </VBox>
    </top>

    <left>
        <!-- Removed MenuItem sidebar as requested -->
    </left>

    <center>
        <VBox spacing="25" style="-fx-padding: 25;">
            <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
                <tabs>
                    <Tab text="RESTAURANT (SĂLI)">
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0;">
                            <FlowPane fx:id="tablesPane" hgap="25" vgap="25" style="-fx-padding: 20;"/>
                        </ScrollPane>
                    </Tab>
                    <Tab text="TERASĂ">
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0;">
                            <FlowPane fx:id="terracePane" hgap="25" vgap="25" style="-fx-padding: 20;"/>
                        </ScrollPane>
                    </Tab>
                    <Tab fx:id="kitchenTab" text="BUCĂTĂRIE (ADMIN)">
                        <VBox spacing="20" styleClass="card" style="-fx-margin: 20 0 0 0;">
                            <Label text="COMENZI PRIMITE ÎN BUCĂTĂRIE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                            <ListView fx:id="kitchenOrdersList" VBox.vgrow="ALWAYS" />
                        </VBox>
                    </Tab>
                </tabs>
            </TabPane>

            <!-- Bottom Tools -->
            <HBox fx:id="staffManagementBox" spacing="20" prefHeight="200">
                <VBox spacing="10" prefWidth="420" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10;">
                    <Label text="STAFF MANAGEMENT" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                    <GridPane hgap="10" vgap="12">
                        <Label text="Full Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="employeeNameField" promptText="e.g. John Doe" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>
                        <Label text="Assigned Role:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="employeeRoleCombo" prefWidth="200" promptText="Select Role" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Personal PIN:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="employeePinField" promptText="e.g. 1234" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="200"/>
                        <Button text="REGISTER STAFF" onAction="#handleSaveEmployee" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <VBox spacing="5" HBox.hgrow="ALWAYS" style="-fx-background-color: #2f3640; -fx-padding: 10; -fx-background-radius: 10;">
                    <Label text="SYSTEM LOG" style="-fx-font-weight: bold; -fx-text-fill: #dcdde1; -fx-font-size: 11px;"/>
                    <TextArea fx:id="logArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS" style="-fx-control-inner-background: #2f3640; -fx-text-fill: #f5f6fa; -fx-font-family: 'Consolas';"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
