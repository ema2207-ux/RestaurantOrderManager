<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.restaurant.gui.RestaurantController"
            stylesheets="@style.css"
            prefHeight="750.0" prefWidth="1100.0">

    <top>
        <VBox style="-fx-background-color: #2c3e50;">
            <MenuBar>
                <Menu text="File">
                    <MenuItem text="Refresh Data" onAction="#handleRefreshData"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit" onAction="#handleExit"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About" onAction="#handleAbout"/>
                </Menu>
            </MenuBar>
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 15 20;">
                <Label text="RESTO MANAGER" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Separator orientation="VERTICAL" style="-fx-opacity: 0.3;"/>
                <Label text="Operations Dashboard" style="-fx-text-fill: #bdc3c7; -fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="LOGOUT" onAction="#handleLogout" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox spacing="15" prefWidth="280" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-border-color: transparent #bdc3c7 transparent transparent;">
            <Label text="MENU ITEMS" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <ListView fx:id="menuListView" VBox.vgrow="ALWAYS" />
            <Label text="Double-click to add to table" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
                <tabs>
                    <Tab text="SALA (Mese)">
                        <HBox spacing="20">
                            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                            <!-- Tables Section -->
                            <VBox spacing="10" prefWidth="320">
                                <Label text="FLOOR PLAN" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                                <ScrollPane fitToWidth="true" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10;">
                                    <FlowPane fx:id="tablesPane" hgap="15" vgap="15" style="-fx-padding: 15;"/>
                                </ScrollPane>
                                <HBox spacing="15" style="-fx-padding: 5;">
                                    <HBox spacing="5" alignment="CENTER_LEFT"><Rectangle width="12" height="12" fill="mediumseagreen" arcWidth="3" arcHeight="3"/><Label text="Free" style="-fx-font-size: 11px;"/></HBox>
                                    <HBox spacing="5" alignment="CENTER_LEFT"><Rectangle width="12" height="12" fill="tomato" arcWidth="3" arcHeight="3"/><Label text="Occupied" style="-fx-font-size: 11px;"/></HBox>
                                </HBox>
                            </VBox>

                            <!-- Order Panel -->
                            <VBox fx:id="selectedTablePane" spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                                <HBox alignment="CENTER_LEFT">
                                    <Label fx:id="selectedTableLabel" text="No Table Selected" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="RESET" onAction="#handleClearOrder" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 5 10;"/>
                                </HBox>

                                <ListView fx:id="orderItemsListView" VBox.vgrow="ALWAYS" />

                                <VBox spacing="15" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8;">
                                    <HBox alignment="CENTER_RIGHT" spacing="15">
                                        <Label text="TOTAL DUE:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                                        <Label fx:id="totalLabel" text="0.00 RON" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                                    </HBox>
                                    <HBox alignment="CENTER_RIGHT" spacing="10">
                                        <RadioButton fx:id="cashRadio" text="CASH" selected="true"><toggleGroup><ToggleGroup fx:id="paymentGroup"/></toggleGroup></RadioButton>
                                        <RadioButton fx:id="cardRadio" text="CARD" toggleGroup="$paymentGroup"/>
                                        <Region prefWidth="10"/>
                                        <Button text="PROCESS PAYMENT" onAction="#handleFinishOrder" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </HBox>
                    </Tab>
                    <Tab fx:id="kitchenTab" text="BUCĂTĂRIE">
                        <VBox spacing="15" style="-fx-padding: 20;">
                            <Label text="COMENZI ACTIVE BUCĂTĂRIE" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                            <ListView fx:id="kitchenOrdersList" VBox.vgrow="ALWAYS" />
                        </VBox>
                    </Tab>
                </tabs>
            </TabPane>

            <!-- Bottom Tools -->
            <HBox spacing="20" prefHeight="200">
                <VBox spacing="10" prefWidth="420" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10;">
                    <Label text="STAFF MANAGEMENT" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                    <GridPane hgap="10" vgap="12">
                        <Label text="Full Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="employeeNameField" promptText="e.g. John Doe" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>
                        <Label text="Assigned Role:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="employeeRoleCombo" prefWidth="200" promptText="Select Role" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Button text="REGISTER STAFF" onAction="#handleSaveEmployee" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <VBox spacing="5" HBox.hgrow="ALWAYS" style="-fx-background-color: #2f3640; -fx-padding: 10; -fx-background-radius: 10;">
                    <Label text="SYSTEM LOG" style="-fx-font-weight: bold; -fx-text-fill: #dcdde1; -fx-font-size: 11px;"/>
                    <TextArea fx:id="logArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS" style="-fx-control-inner-background: #2f3640; -fx-text-fill: #f5f6fa; -fx-font-family: 'Consolas';"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>

