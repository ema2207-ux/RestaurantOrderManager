<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.restaurant.gui.RegisterController" style="-fx-background-color: #2c3e50;">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="ÎNREGISTRARE STAFF" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="nameField" promptText="Nume Complet" style="-fx-font-size: 14px;"/>
    <ComboBox fx:id="roleCombo" promptText="Selectează Rol" maxWidth="Infinity" style="-fx-font-size: 14px;"/>
    <TextField fx:id="pinField" promptText="PIN Acces" style="-fx-font-size: 14px;"/>

    <Button text="SALVEAZĂ CONT" onAction="#handleRegister" maxWidth="Infinity"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10;"/>

    <Button text="ÎNAPOI LA LOGIN" onAction="#handleBack" maxWidth="Infinity"
            style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-padding: 8;"/>
</VBox>

